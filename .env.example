# Copy to `.env` and fill in. The values come from your Ampersand
# Dashboard for the project and integration that the demo runs against.

AMP_PROJECT_ID=
AMP_API_KEY=
AMP_GROUP_REF=

# Integration IDs (the id of each integration in your Ampersand project,
# visible at /v1/projects/<projectId>/integrations).
AMP_SF_INTEGRATION_ID=
AMP_SN_INTEGRATION_ID=
